# Supabase — copier dans .env et remplir les valeurs
# Le fichier .env est gitignore — ne jamais committer les vraies valeurs

EXPO_PUBLIC_SUPABASE_URL=https://flmslcdzjuifkivmzins.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ─────────────────────────────────────────────────────────────────────────────
# EAS Build — secrets à configurer via CLI (pas dans ce fichier)
#
#   eas secret:create --scope project --name EXPO_PUBLIC_SUPABASE_URL    --value "https://..."
#   eas secret:create --scope project --name EXPO_PUBLIC_SUPABASE_ANON_KEY --value "eyJ..."
#   eas secret:create --scope project --name RESEND_API_KEY               --value "re_..."
#   eas secret:create --scope project --name CRON_SECRET                  --value "<random>"
#
# Edge Functions — secrets à configurer via Supabase CLI
#
#   supabase secrets set RESEND_API_KEY=re_...
#   supabase secrets set CRON_SECRET=<random>
#   supabase functions deploy notify-cancel
#   supabase functions deploy rgpd-purge
#
# Play Store — clé de compte de service
#   google-play-service-account.json  (gitignore, ne pas committer)
#   Obtenir sur : Google Play Console → Setup → API access
# ─────────────────────────────────────────────────────────────────────────────
