{
  "expo": {
    "name": "AvecToi",
    "slug": "avectoi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "avectoi",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#0D1B2E",
      "resizeMode": "contain"
    },
    "notification": {
      "color": "#F0B429",
      "androidMode": "default"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D1B2E"
      },
      "package": "care.avectoi.app",
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.USE_EXACT_ALARM",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#F0B429",
          "defaultChannel": "visits"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "AvecToi accède à vos photos pour partager des souvenirs.",
          "cameraPermission": "AvecToi accède à votre caméra pour prendre des photos."
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "AvecToi accède à votre calendrier pour ajouter vos créneaux de visite."
        }
      ],
      "expo-font",
      "expo-asset"
    ],
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./favicon.png"
    },
    "experiments": {
      "typedRoutes": true
    },
    "owner": "ei-hcs-consulting",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "305abfe3-5d04-449f-9b06-8975f2196588"
      }
    }
  }
}
